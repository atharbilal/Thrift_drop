{
  "expo": {
    "name": "ThriftDrop",
    "slug": "thriftdrop",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "thriftdrop",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.atharbilal.thriftdrop",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "ThriftDrop needs access to your camera to let you upload photos of thrift finds.",
        "NSPhotoLibraryUsageDescription": "ThriftDrop needs access to your photo library to let you select and upload existing photos.",
        "NSLocationWhenInUseUsageDescription": "ThriftDrop uses your location to show thrift finds and deals near you.",
        "UIBackgroundModes": [
          "background-fetch",
          "background-processing"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.atharbilal.thriftdrop",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "predictiveBackGestureEnabled": false,
      "compileSdkVersion": 34,
      "targetSdkVersion": 34
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow ThriftDrop to access your camera to upload photos of thrift finds"
        }
      ],
      [
        "expo-location",
        {
          "locationPermission": "Allow ThriftDrop to access your location to show nearby thrift finds"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "87806cd2-3270-469b-a539-f86d41a02eea"
      }
    }
  }
}
